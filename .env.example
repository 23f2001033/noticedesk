# Copy to .env for local dev. Never commit the real .env — see .gitignore.
# In deployed environments these are injected via Secret Manager, not this file.

# --- Runtime (Phase 0) ---
ENV=dev
PORT=8080
GCP_PROJECT_ID=
GCP_REGION=asia-south1

# --- Firebase Auth (Phase 0 skeleton; real project wiring TBD) ---
FIREBASE_PROJECT_ID=
# Local dev only — path to a service account JSON, never committed. Cloud Run uses
# the attached service account instead; this var should be unset in deployed envs.
GOOGLE_APPLICATION_CREDENTIALS=

# --- Gemini API (Phase 1+) --- verify current model IDs at ai.google.dev, never hardcode
GEMINI_API_KEY=
GEMINI_MODEL_FAST=
GEMINI_MODEL_SMART=
GEMINI_MODEL_EMBED=

# --- Cloud Storage (Phase 1+) ---
CLOUD_STORAGE_BUCKET=

# --- WhatsApp Business Cloud API (Phase 1+) ---
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=
WA_VERIFY_TOKEN=
WA_APP_SECRET=

# --- Razorpay (Phase 2+) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Cloud Scheduler / OIDC-protected task endpoints (Phase 2+) ---
TASKS_OIDC_AUDIENCE=
