# Copy to .env.local for local dev (Vite auto-loads it; never commit the real file).
# Values come from the Firebase project's web app config once one exists (see PROGRESS.md).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# FastAPI origin. Empty string works when the webapp is served as a static
# build by FastAPI itself (same origin); set an absolute URL only when
# running `npm run dev` against a separately-hosted backend.
VITE_API_BASE_URL=
